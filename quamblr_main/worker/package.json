{
  "name": "quamblr-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 execute quamblr --file=./schema.sql",
    "db:migrate:local": "wrangler d1 execute quamblr --local --file=./schema.sql",
    "db:migrate:verify": "wrangler d1 execute quamblr --file=./migrations/001_add_verification_fields.sql",
    "db:migrate:verify:local": "wrangler d1 execute quamblr --local --file=./migrations/001_add_verification_fields.sql"
  },
  "devDependencies": {
    "wrangler": "^4.76.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "hono": "^4.0.0",
    "jose": "^5.2.0"
  }
}
